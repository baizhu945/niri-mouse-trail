# Mouse Trail Configuration
# Copy this file to ~/.config/mouse-trail/config
# Lines starting with # are comments
# Use import=path to include another config file

# Trail color (hex, with or without #)
color=80c8ff

# Trail opacity (0-1)
alpha=0.6

# Head radius in pixels
width=5

# Trail duration in milliseconds
length=400

# Stationary detection threshold in pixels
min_speed=2

# EMA smoothing factor (0-1, higher = smoother)
smooth_factor=0.6

# Auto color cycling (HSL rainbow)
color_cycle=off

# Color cycle period in seconds
cycle_speed=5

# Import another config file
#import=/path/to/theme.conf
